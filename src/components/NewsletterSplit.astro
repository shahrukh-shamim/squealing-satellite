---

<section class="newsletter-split">
  <div class="container split-grid">
    <div class="split-image-wrap">
      <img
        src="/newsletter-mug.jpg"
        alt="Cozy mug on a soft knitted blanket"
        class="split-image"
        loading="lazy"
      />
    </div>

    <div class="split-content">
      <div class="content-inner">
        <h2>Let’s Stay Connected</h2>
        <p>
          Join our cozy little community and get weekly love letters straight to your inbox.
        </p>

        <form class="newsletter-form">
          <input type="email" placeholder="Enter your email address" />
          <button type="submit">Join the Family ♡</button>
        </form>

        <span class="fine-print">No spam, just love ♡</span>
        <div class="flower-deco">❀</div>
      </div>
    </div>
  </div>
</section>

<style>
  .newsletter-split {
    padding: 28px 0 36px;
    background: #fbf7f3;
  }

  .container {
    width: min(1180px, calc(100% - 48px));
    margin: 0 auto;
  }

  .split-grid {
    display: grid;
    grid-template-columns: 1.08fr 0.92fr;
    gap: 0;
    align-items: stretch;
    overflow: hidden;
    border-radius: 0;
  }

  .split-image-wrap {
    min-height: 360px;
  }

  .split-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .split-content {
    background: #f5efea;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    min-height: 360px;
  }

  .content-inner {
    width: min(100%, 430px);
    padding: 42px 40px;
    position: relative;
    z-index: 2;
  }

  .content-inner h2 {
    margin: 0 0 14px;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 2.5rem;
    line-height: 1.15;
    font-weight: 500;
    color: #765d53;
  }

  .content-inner p {
    margin: 0 0 22px;
    max-width: 320px;
    font-size: 1rem;
    line-height: 1.8;
    color: #8a746a;
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 320px;
  }

  .newsletter-form input {
    height: 46px;
    border: 1px solid #eadccf;
    border-radius: 8px;
    padding: 0 14px;
    font-size: 0.95rem;
    background: #fffdfa;
    color: #7c685d;
    outline: none;
  }

  .newsletter-form input::placeholder {
    color: #b29b90;
  }

  .newsletter-form input:focus {
    border-color: #d2ae95;
    box-shadow: 0 0 0 3px rgba(210, 174, 149, 0.12);
  }

  .newsletter-form button {
    height: 48px;
    border: none;
    border-radius: 999px;
    background: #c89c78;
    color: #fff;
    font-size: 0.96rem;
    cursor: pointer;
    box-shadow: 0 10px 22px rgba(200, 156, 120, 0.2);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .newsletter-form button:hover {
    transform: translateY(-1px);
    opacity: 0.96;
  }

  .fine-print {
    display: inline-block;
    margin-top: 14px;
    font-size: 0.92rem;
    color: #9a8377;
  }

  .flower-deco {
    position: absolute;
    right: 6px;
    bottom: 2px;
    font-size: 5.2rem;
    color: #e6cfbe;
    opacity: 0.7;
    line-height: 1;
    pointer-events: none;
  }

  @media (max-width: 900px) {
    .split-grid {
      grid-template-columns: 1fr;
    }

    .split-image-wrap,
    .split-content {
      min-height: 300px;
    }

    .content-inner {
      width: 100%;
      padding: 34px 24px;
      text-align: center;
    }

    .content-inner p,
    .newsletter-form {
      max-width: none;
    }

    .flower-deco {
      right: 12px;
      bottom: 8px;
      font-size: 4rem;
    }
  }

  @media (max-width: 640px) {
    .newsletter-split {
      padding: 18px 0 28px;
    }

    .container {
      width: min(100% - 24px, 1180px);
    }

    .split-image-wrap,
    .split-content {
      min-height: 260px;
    }

    .content-inner h2 {
      font-size: 2rem;
    }
  }
</style>