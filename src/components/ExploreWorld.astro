---

const cards = [
  {
    title: "Home Decor",
    image: "/card-home-decor.jpg",
    icon: "⌂",
    alt: "Soft neutral home decor basket with cozy blankets",
  }, 
  {
    title: "Kids & Play",
    image: "/card-kids-play.jpg",
    icon: "⚘",
    alt: "Young child sitting with a teddy bear in a cozy room",
  },
  {
    title: "Recipes",
    image: "/card-recipes.jpg",
    icon: "☕",
    alt: "Pancakes and berries on a warm breakfast table",
  },
  {
    title: "Mom Self-Care",
    image: "/card-self-care.jpg",
    icon: "❦",
    alt: "Open book, dried flowers, and a calm self-care setup",
  },
];
---

<section class="explore-world">
  <div class="container">
    <div class="section-head">
      <h2>Explore My World</h2>
      <p>Pieces of my everyday life you might love too</p>
    </div>

    <div class="cards-grid">
      {cards.map((card) => (
        <article class="world-card">
          <img src={card.image} alt={card.alt} class="card-image" loading="lazy" />

          <div class="card-badge" aria-hidden="true">
            <span>{card.icon}</span>
          </div>

          <div class="card-label">
            <a href="#">{card.title}</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .explore-world {
    padding: 28px 0 44px;
    background: #fbf7f3;
  }

  .container {
    width: min(1180px, calc(100% - 48px));
    margin: 0 auto;
  }

  .section-head {
    text-align: center;
    margin-bottom: 28px;
  }

  .section-head h2 {
    margin: 0 0 10px;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 3rem;
    line-height: 1.12;
    font-weight: 500;
    color: #755d53;
  }

  .section-head p {
    margin: 0;
    font-size: 1rem;
    color: #8a766b;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 22px;
  }

  .world-card {
    position: relative;
    overflow: hidden;
    border-radius: 24px;
    background: #f1e7df;
    box-shadow: 0 18px 34px rgba(113, 90, 76, 0.08);
  }

  .card-image {
    width: 100%;
    display: block;
    aspect-ratio: 1 / 0.9;
    object-fit: cover;
  }

  .card-badge {
    position: absolute;
    left: 50%;
    bottom: 46px;
    transform: translateX(-50%);
    width: 78px;
    height: 78px;
    border-radius: 999px;
    background: rgba(255, 249, 244, 0.95);
    box-shadow: 0 10px 24px rgba(101, 77, 63, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-badge span {
    font-size: 1.8rem;
    color: #bc987f;
  }

  .card-label {
    position: absolute;
    left: 50%;
    bottom: 12px;
    transform: translateX(-50%);
    min-width: 76%;
    text-align: center;
    background: rgba(255, 250, 246, 0.96);
    border-radius: 999px;
    padding: 12px 16px;
    box-shadow: 0 8px 20px rgba(95, 73, 60, 0.08);
  }

  .card-label a {
    text-decoration: none;
    color: #7a645a;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.35rem;
    font-weight: 500;
  }

  .card-label a:hover {
    color: #b2886e;
  }

  @media (max-width: 1024px) {
    .cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .explore-world {
      padding: 18px 0 34px;
    }

    .container {
      width: min(100% - 24px, 1180px);
    }

    .section-head h2 {
      font-size: 2.2rem;
    }

    .cards-grid {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .card-badge {
      width: 68px;
      height: 68px;
      bottom: 42px;
    }

    .card-label a {
      font-size: 1.2rem;
    }
  }
</style>