---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HeroSlider from "../components/HeroSlider.astro";
import AboutIntro from "../components/AboutIntro.astro";
import ExploreWorld from "../components/ExploreWorld.astro";
import NewsletterSplit from "../components/NewsletterSplit.astro";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Little Home</title>
    <meta name="description" content="Motherhood & lifestyle blog" />
    <meta property="og:title" content="Little Home" />
    <meta property="og:description" content="Motherhood & lifestyle blog" />
    <meta property="og:image" content="/hero.jpg" />
    <style>
      :root {
        color-scheme: light;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
		font-family: 'Inter', Arial, sans-serif;
		background: #fbf7f3;
      }

	  h1, h2, h3 {
		font-family: 'Playfair Display', serif;
	  }

      main {
        min-height: 60vh;
      }
    </style>
	<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  </head>
  <body>
    <Header />
    <main>
      <HeroSlider />
      <AboutIntro />
      <ExploreWorld />
      <NewsletterSplit />
    </main>
    <Footer />
  </body>
</html>